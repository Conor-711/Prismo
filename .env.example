# ============================================================
#  Reddit 版 Kaito Pro — 环境变量样例
#  复制为 .env 并填入真实值：  cp .env.example .env
# ============================================================

# ---- Reddit Data API ----------------------------------------
# 在 https://www.reddit.com/prefs/apps 创建一个 "script" 类型 app。
# 注意：2025-11 起 Reddit Responsible Builder Policy 要求 app 预先申请审批
#       （含个人/非商用项目）。请确认你的 app 已获批。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# User-Agent 必须唯一且含联系人用户名，例如：
REDDIT_USER_AGENT=reddit-kaito-pro/0.1 (by u/your_reddit_username)

# ---- Anthropic (Claude) -------------------------------------
ANTHROPIC_API_KEY=
# 模型（可改）：高并发打标用 Haiku，综合/叙事用 Sonnet，简报可用 Opus
ANTHROPIC_MODEL_TAG=claude-haiku-4-5
ANTHROPIC_MODEL_SYNTH=claude-sonnet-4-6
ANTHROPIC_MODEL_BRIEF=claude-sonnet-4-6

# ---- Database (SQLAlchemy URL，Python 管线用) ----------------
# 本地开发默认 SQLite（零配置）：
DATABASE_URL=sqlite:///./data/dev.db
#
# 云端（Supabase = Postgres，推荐：数据真正存在云端、可持久化、避免重复分析）：
# 从 Supabase → Project Settings → Database → Connection string → URI 复制（含密码），形如：
#   DATABASE_URL=postgresql://postgres.xxxx:[你的密码]@aws-0-xxx.pooler.supabase.com:6543/postgres
# 粘贴成上面这种 postgres 串后，整条管线就写入云端（会自动转 psycopg + 强制 SSL，无需手改）。
# 一次性迁移与日常构建步骤见 CLOUD_DB.md（make cloud-init / make site-cloud）。

# ---- 管线参数（可选，留空用默认） ---------------------------
INGEST_POST_LIMIT=120          # 每板块每来源拉取条数
INGEST_COMMENT_MIN_SCORE=15    # 顶层评论入库的最低分（控量）
MINDSHARE_WINDOW_HOURS=24      # 默认 mindshare 窗口
